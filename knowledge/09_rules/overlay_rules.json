{
  "schema_version": "1.1",
  "market": "XAUUSD",
  "entry_timeframe": "M5",
  "usage": "read_only_reference",
  "category": "overlay_rules",
  "drawing_rules": [
    {
      "element": "support",
      "color": "blue",
      "style": "thin solid line",
      "label": "SUP"
    },
    {
      "element": "resistance",
      "color": "orange-red",
      "style": "thin solid line",
      "label": "RES"
    },
    {
      "element": "buy",
      "color": "green",
      "style": "marker and expected path"
    },
    {
      "element": "sell",
      "color": "red",
      "style": "marker and expected path"
    },
    {
      "element": "stop_loss",
      "color": "red",
      "style": "dashed thin line",
      "label": "SL"
    },
    {
      "element": "targets",
      "color": "green",
      "style": "thin line",
      "labels": [
        "TP1",
        "TP2",
        "TP3"
      ]
    },
    {
      "element": "fvg",
      "color": "purple",
      "style": "transparent rectangle",
      "label": "FVG"
    },
    {
      "element": "bos_choch",
      "color": "gold",
      "style": "small label and thin segment"
    },
    {
      "element": "expected_path",
      "color_rule": "green bullish / red bearish",
      "style": "curved or segmented dashed path"
    },
    {
      "element": "single_best_trade",
      "maximum_drawn_trades": 1,
      "selection": "highest estimated probability with valid technical structure",
      "content": [
        "direction",
        "estimated success probability",
        "entry",
        "structure-based stop",
        "transparent target zone",
        "one expected path"
      ]
    }
  ],
  "constraints": [
    "لا تغطِ الشموع قدر الإمكان",
    "لا توجد لوحة جانبية أو لوحة سفلية",
    "ارسم صفقة واحدة فقط وهي الأعلى احتمالًا",
    "وقف الخسارة من بنية الشارت وليس مسافة ثابتة",
    "السهم أحمر للهبوط وأخضر للصعود",
    "تظهر الصورة الناتجة كأن محللًا رسم على لقطة المستخدم نفسها"
  ]
}
