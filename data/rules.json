  "default_timeframe": "M5",
  "rules": [
    {
      "id": "breakout_buy",
      "name_ar": "شراء بعد كسر المقاومة",
      "enabled": true,
      "conditions": [
        "close_above_resistance",
        "body_above_level_percent >= 60",
        "retest_holds_above_level"
      ],
      "base_score": 80
    },
    {
      "id": "rejection_sell",
      "name_ar": "بيع بعد رفض المقاومة",
      "enabled": true,
      "conditions": [
        "upper_wick_body_ratio >= 1.5",
        "close_below_resistance",
        "next_candle_bearish"
      ],
      "base_score": 72
    },
    {
      "id": "false_breakout",
      "name_ar": "كسر كاذب",
      "enabled": true,
      "conditions": [
        "wick_crosses_level",
        "candle_closes_back_inside_range"
      ],
      "base_score": 68
    }
  ]
